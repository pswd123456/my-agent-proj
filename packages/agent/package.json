{
  "name": "@ai-app-template/agent",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./contracts/workspace-api": {
      "types": "./dist/contracts/workspace-api.d.ts",
      "import": "./dist/contracts/workspace-api.js"
    },
    "./runtime/assembly": {
      "types": "./dist/runtime/assembly.d.ts",
      "import": "./dist/runtime/assembly.js"
    }
  },
  "scripts": {
    "dev": "tsc -p tsconfig.json --watch --preserveWatchOutput",
    "build": "tsc -p tsconfig.json",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-app-template/db": "workspace:*",
    "@ai-app-template/domain": "workspace:*",
    "@anthropic-ai/sdk": "^0.90.0",
    "@langchain/langgraph": "1.2.5",
    "@modelcontextprotocol/sdk": "1.29.0",
    "drizzle-orm": "0.45.1",
    "js-tiktoken": "1.0.21",
    "smol-toml": "1.6.1",
    "typescript-language-server": "5.1.3",
    "vscode-jsonrpc": "8.2.1",
    "vscode-languageserver-protocol": "3.17.5",
    "zod": "4.3.6"
  },
  "devDependencies": {}
}
