{
  "name": "ai-app-template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "set -a && . ./.env && set +a && turbo run dev --parallel",
    "dev:packages": "turbo run dev --parallel --filter='./packages/*'",
    "build": "turbo run build",
    "design:lint": "bunx @google/design.md lint DESIGN.md",
    "lint": "turbo run lint",
    "minimax:smoke": "bun scripts/minimax-smoke.ts",
    "product1:cli": "bun scripts/product1-cli.ts",
    "product1:smoke": "bun scripts/product1-smoke.ts",
    "stage1:smoke": "bun scripts/stage1-smoke.ts",
    "api:session-smoke": "bun scripts/session-api-smoke.ts",
    "agent:runtime-smoke": "bun scripts/agent-runtime-smoke.ts",
    "db:postgres-session-smoke": "bun scripts/postgres-session-smoke.ts",
    "db:generate": "bunx drizzle-kit generate --config packages/db/drizzle.config.ts",
    "db:migrate": "bunx drizzle-kit migrate --config packages/db/drizzle.config.ts",
    "db:check": "bunx drizzle-kit check --config packages/db/drizzle.config.ts",
    "web:workbench-smoke": "bun scripts/web-workbench-smoke.ts",
    "typecheck": "turbo run typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@eslint/js": "10.0.1",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "10.1.0",
    "drizzle-orm": "0.45.1",
    "prettier": "3.8.1",
    "turbo": "2.8.20",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2"
  }
}
