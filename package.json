{
  "name": "ai-app-template",
  "version": "0.1.0",
  "private": true,
  "packageManager": "bun@1.3.12",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "set -a && . ./.env && set +a && turbo run dev --parallel",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "minimax:smoke": "bun scripts/minimax-smoke.ts",
    "product1:cli": "bun scripts/product1-cli.ts",
    "product1:smoke": "bun scripts/product1-smoke.ts",
    "stage1:smoke": "bun scripts/stage1-smoke.ts",
    "ui1:api-smoke": "bun scripts/ui1-api-smoke.ts",
    "ui1:postgres-smoke": "bun scripts/ui1-postgres-smoke.ts",
    "ui1:runtime-smoke": "bun scripts/ui1-runtime-smoke.ts",
    "ui1:web-smoke": "bun scripts/ui1-web-smoke.ts",
    "typecheck": "turbo run typecheck",
    "format": "prettier --check .",
    "format:write": "prettier --write ."
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.90.0",
    "@eslint/js": "10.0.1",
    "@types/node": "25.5.0",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "eslint": "10.1.0",
    "prettier": "3.8.1",
    "turbo": "2.8.20",
    "typescript": "5.9.3",
    "typescript-eslint": "8.57.2"
  }
}
