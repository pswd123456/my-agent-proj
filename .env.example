DATABASE_URL=postgres://postgres:postgres@localhost:5432/ai_app_template
OPENAI_API_KEY=
BETTER_AUTH_SECRET=
WEB_PORT=3000
API_PORT=3001
# Optional when the web app is not served through /api on the same origin.
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:3001

# Firecrawl MCP / CLI web access
FIRECRAWL_API_KEY=

# lsp does not need a separate server URL.
# The runtime starts typescript-language-server locally from workspace deps.

# MiniMax quick smoke test
MINIMAX_API_KEY=
ANTHROPIC_BASE_URL=https://api.minimaxi.com/anthropic
ANTHROPIC_MODEL=MiniMax-M2.7
ANTHROPIC_MAX_TOKENS=16384
ANTHROPIC_TOOL_CHOICE=auto

# DeepSeek Anthropic-compatible
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/anthropic
